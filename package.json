{
  "name": "system-master",
  "version": "1.0.0",
  "description": "Next-gen system utility for Windows",
  "main": "dist/main.js",
  "scripts": {
    "start": "npx tsc -p tsconfig.electron.json && npx vite build && npx electron .",
    "dev": "npx tsc -p tsconfig.electron.json && concurrently \"npx vite\" \"wait-on http://localhost:3000 && npx electron .\"",
    "dev:react": "vite",
    "build": "tsc -p tsconfig.electron.json && vite build && electron-builder",
    "build:win": "tsc -p tsconfig.electron.json && vite build && electron-builder --win"
  },
  "dependencies": {
    "lucide-react": "^0.344.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "electron": "^41.10.1",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.systemmaster.app",
    "productName": "System Master",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    }
  }
}
